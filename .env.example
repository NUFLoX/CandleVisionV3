# Rename this file to .env and fill only what you really use.
# Never commit real tokens, API keys, session files, or exchange secrets.

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bybit API keys (optional; leave empty for signals-only mode)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Environment selection
# true = Bybit testnet endpoints, false = production public endpoints.
BYBIT_TESTNET=false
# Legacy compatibility for old modules that still read TESTNET.
TESTNET=false
SIGNALS_ONLY=true

# Scout scanner timeframes (comma-separated)
SCOUT_SCAN_TIMEFRAMES=1m,5m,15m,30m

# =========================
# OrderFlow V1.2
# =========================
OF_QUOTE_COIN=USDT
OF_REALTIME_SYMBOLS_LIMIT=40
OF_MACRO_SYMBOLS_LIMIT=95
OF_SCAN_EVERY_SECONDS=20
OF_MACRO_EVERY_SECONDS=7200
OF_BOOK_DEPTH=25
OF_MIN_NOTIONAL_24H=10000000
OF_MIN_LAST_PRICE=0.000001
OF_SUPPORT_LOOKBACK_BARS=60
OF_SUPPORT_TOLERANCE_BPS=18
OF_RESISTANCE_TOLERANCE_BPS=18
OF_MIN_ABSORPTION_SCORE=4.2
OF_MIN_BREAKOUT_SCORE=4.4
OF_MIN_MACRO_SCORE=3.4
OF_TAPE_WINDOW_SECONDS=15
OF_WALL_PERSISTENCE_SECONDS=12
OF_STALE_BOOK_SECONDS=6
OF_SIGNAL_COOLDOWN_SECONDS=300
OF_MACRO_SYMBOL_COOLDOWN_MIN=240
OF_FIXED_RISK_PCT=0.35
OF_ATR_STOP_MULT=1.2
OF_TP1_RR=1.5
OF_TP2_RR=2.5

# Realtime quality filters
OF_MIN_REALTIME_TRADE_NOTIONAL=50000
OF_MIN_DELTA_ABS=15000
OF_MIN_WALL_PERSISTENCE=0.22
OF_MIN_BOOK_IMBALANCE_ABS=0.14
OF_MAX_SPREAD_BPS=8
OF_MIN_BREAKOUT_TURNOVER_MULTIPLE=1.5

# Macro quality filters
OF_MACRO_REQUIRE_BREAKOUT_PROXIMITY=true
OF_MACRO_MAX_CLOSE_TO_BREAKOUT_PCT=2.2
OF_MACRO_MIN_VOLUME_EXPANSION=1.8
OF_MACRO_MIN_TURNOVER_60=50000000
OF_MACRO_MIN_TURNOVER_240=120000000
OF_MACRO_MIN_TURNOVER_D=350000000
OF_MACRO_REQUIRE_TREND_ALIGNMENT=true
OF_MACRO_MAX_CORRIDOR_PCT_60=4.0
OF_MACRO_MAX_CORRIDOR_PCT_240=7.0
OF_MACRO_MAX_CORRIDOR_PCT_D=16.0
OF_SYMBOLS_ALLOWLIST=
OF_SYMBOLS_BLOCKLIST=
OF_WS_HEARTBEAT_SECONDS=20

# === Accumulation V1 ===
ACC_QUOTE_COIN=USDT
ACC_REALTIME_SYMBOLS_LIMIT=20
ACC_MACRO_SYMBOLS_LIMIT=50
ACC_MARKET_CATEGORIES=linear,spot
ACC_SCAN_EVERY_SECONDS=12
ACC_REALTIME_INTERVALS=1,5,15
ACC_PREIMPULSE_INTERVALS=5,15,60
ACC_MACRO_EVERY_SECONDS=1800
ACC_BOOK_DEPTH=20
ACC_MIN_NOTIONAL_24H=15000000
ACC_MIN_LAST_PRICE=0.000001
ACC_SUPPORT_LOOKBACK_BARS=60
ACC_RESISTANCE_LOOKBACK_BARS=60
ACC_SUPPORT_TOLERANCE_BPS=22
ACC_BREAKOUT_READY_BPS=55
ACC_TAPE_WINDOW_SECONDS=18
ACC_WALL_PERSISTENCE_SECONDS=18
ACC_WS_HEARTBEAT_SECONDS=20
ACC_STALE_BOOK_SECONDS=12
ACC_SIGNAL_COOLDOWN_SECONDS=1800
ACC_ATR_STOP_MULT=1.25
ACC_TP1_RR=1.6
ACC_TP2_RR=2.8
ACC_MIN_TRADE_NOTIONAL=30000
ACC_MIN_SELL_PRESSURE_NOTIONAL=12000
ACC_MIN_WALL_PERSISTENCE=0.18
ACC_MIN_BOOK_IMBALANCE=0.08
ACC_MAX_SPREAD_BPS=10
ACC_MIN_ABSORPTION_SCORE=3.6
ACC_MIN_READY_SCORE=4.8
ACC_MIN_MACRO_SCORE=3.8
ACC_MACRO_BASE_LOOKBACK=24
ACC_MACRO_MAX_RANGE_PCT_60=6.0
ACC_MACRO_MAX_RANGE_PCT_240=9.0
ACC_MACRO_MAX_RANGE_PCT_D=18.0
ACC_MACRO_MIN_TURNOVER_60=40000000
ACC_MACRO_MIN_TURNOVER_240=100000000
ACC_MACRO_MIN_TURNOVER_D=250000000
ACC_MACRO_MIN_CLOSE_POS=0.62
ACC_MACRO_MAX_RECENT_IMPULSE_PCT=7.5
ACC_MACRO_MIN_VOLUME_EXPANSION=1.2
ACC_MACRO_SYMBOL_COOLDOWN_MIN=360
ACC_SYMBOLS_ALLOWLIST=
ACC_SYMBOLS_BLOCKLIST=XAUTUSDT
ACC_SYMBOL_EXCLUDE_PATTERNS=1000*,*TEST*,*DEMO*,*USDC
ACC_TELEGRAM_SEND_CHARTS=true
ACC_CHART_BARS_MACRO=80
ACC_CHART_BARS_REALTIME=120
ACC_RESISTANCE_BUFFER_BPS=12
ACC_SECOND_RESISTANCE_BUFFER_BPS=18
ACC_MIN_REWARD_TO_R1=0.75
ACC_MIN_RESISTANCE_GAP_BPS=10
ACC_SIGNAL_MODE=CONFIRMED_MODE
ACC_REST_TIMEOUT_SECONDS=25
ACC_REST_RETRIES=2

# =========================
# Dashboard API
# =========================
DASHBOARD_API_URL=http://127.0.0.1:8000
DASHBOARD_STATE_PATH=data/dashboard_state.json
# Optional hardening: when set, /api/ingest/* requires Authorization: Bearer <token>.
DASHBOARD_INGEST_TOKEN=
# Signal outcome analyzer storage and lookahead window.
DASHBOARD_SIGNAL_STATS_DB=data/signal_stats.db
DASHBOARD_SIGNAL_LOOKAHEAD_BARS=120
BYBIT_PUBLIC_BASE_URL=https://api.bybit.com
